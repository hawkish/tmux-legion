{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.tmux/plugins/tmux-legion/bin/tmux-legion hook claude SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.tmux/plugins/tmux-legion/bin/tmux-legion hook claude UserPromptSubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.tmux/plugins/tmux-legion/bin/tmux-legion hook claude PreToolUse"
          }
        ]
      }
